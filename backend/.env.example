# Copy this file to .env and fill in your values
# -----------------------------------------------

# OpenRouter API key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Fast model — used for first-pass consistency & ghost partner checks
# Free options:  meta-llama/llama-4-maverick:free, qwen/qwen3-235b-a22b:free, google/gemma-3-27b-it:free
# Cheap options: google/gemini-2.5-flash, openai/gpt-4o-mini
FAST_MODEL=meta-llama/llama-4-maverick:free

# Reasoning model — used for deep analysis & conflict mediation
# Free options:  qwen/qwen3-235b-a22b:free, microsoft/phi-4-reasoning-plus:free
# Cheap options: google/gemini-2.5-flash, anthropic/claude-3.5-haiku
REASONING_MODEL=qwen/qwen3-235b-a22b:free

# Embedding model — used for vector similarity search
# Options: openai/text-embedding-3-small ($0.02/M), or "local" for free sentence-transformers
EMBEDDING_MODEL=local

# Database
DATABASE_URL=sqlite:///./inductive_lens.db
CHROMA_PERSIST_DIR=./chroma_data
